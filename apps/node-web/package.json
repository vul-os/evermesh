{
  "name": "@evermesh/node-web",
  "version": "0.0.1",
  "private": true,
  "description": "Evermesh node desktop client frontend (Tauri 2 webview): browse a gateway's catalog, play back pinned/offline media, manage pins and budgets. All verification and HTTP happens in the Rust side (crates/evermesh-node) via `invoke()` — this app ships no WASM kernel.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@evermesh/ui": "workspace:*",
    "@fontsource/hanken-grotesk": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "@fontsource/syne": "^5.1.0",
    "@tauri-apps/api": "^2.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.6.0",
    "vite": "^5.4.6"
  }
}
